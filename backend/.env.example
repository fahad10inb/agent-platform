# Copy this file to ".env" and fill in real values. The real ".env" is
# gitignored so your secrets never get committed. This ".env.example" is the
# committed template that documents WHICH settings exist.

ENVIRONMENT=development

GEMINI_API_KEY=
DATABASE_URL=

# Master key for admin endpoints (list all businesses, read any business's
# bookings). Generate a strong random one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to LOCK all admin endpoints (secure by default).
ADMIN_API_KEY=
